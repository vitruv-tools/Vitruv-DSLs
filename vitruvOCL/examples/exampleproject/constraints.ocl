-- ============================================================
-- 9. exists(~) — no filter
-- ============================================================

context family::Member inv existsTildetrueForFather:
  self.firstName == "Homer" implies
    persons::Person.allInstances().exists(~)

context family::Member inv existsTildefalseForDaughter:
  self.firstName == "Lisa" implies
    not persons::Person.allInstances().exists(~)

-- ============================================================
-- 10. exists(~, Tag='x')
-- ============================================================

context family::Member inv existsTildeTagHusbandtrueForFather:
  self.firstName == "Homer" implies
    persons::Person.allInstances().exists(~, Tag = "Husband")

context family::Member inv existsTildeTagWifefalseForFather:
  self.firstName == "Homer" implies
    not persons::Person.allInstances().exists(~, Tag = "Wife")

context family::Member inv existsTildeTagSontrueForSon:
  self.firstName == "Bart" implies
    persons::Person.allInstances().exists(~, Tag = "Son")

context family::Member inv existsTildeTagNonExistentfalse:
  not persons::Person.allInstances().exists(~, Tag = "NoSuchTag")

context family::Member inv existsTildeTagWifetrueForMother:
  self.firstName == "Marge" implies
    persons::Person.allInstances().exists(~, Tag = "Wife")

