context family::Member inv selectTildeTagNonExistentempty:
  persons::Person.allInstances().select(~, Tag = "NoSuchTag").isEmpty()

context family::Member inv selectTildeTagWifenotEmptyforMother:
  self.firstName == "Marge" implies
