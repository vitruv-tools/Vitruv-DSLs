context family::Member inv existsTildeTypeFemaletrueForMother:
  self.firstName == "Marge" implies
    persons::Person.allInstances().exists(~, Type = persons::Female)

context family::Member inv existsTildeTypeMalefalseForMother:
  self.firstName == "Marge" and 
  not persons::Person.allInstances().exists(~, Type = persons::Male)

